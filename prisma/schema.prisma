generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// NextAuth Required Models
// ==========================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==========================================
// Portfolio Content Models
// ==========================================

/// Key-value JSON store for site-wide config (userData, metaDescriptions, ctaTexts, tagColors)
model SiteConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
}

model Experience {
  id         String   @id @default(cuid())
  title      String
  company    String
  iconUrl    String
  iconBg     String
  date       String
  websiteUrl String
  points     String[]
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Project {
  id                String   @id @default(cuid())
  title             String
  description       String   @db.Text
  color             String
  isPriority        Boolean  @default(false)
  videoKey          String
  stack             String
  techImage         String
  tags              String[]
  category          String
  technologyFeature String[]
  packages          Json?
  env               Json?
  youtubeLink       String
  githubLink        String
  downloadLinks     Json?
  projectImage      String
  projectVideo      String
  image             Json
  websiteUrl        String
  isRecent          Boolean  @default(false)
  sortOrder         Int      @default(0)
  isSlider          Boolean  @default(false)
  sliderOrder       Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Skill {
  id        String   @id @default(cuid())
  skillName String
  imageUrl  String
  width     Int      @default(80)
  height    Int      @default(80)
  category  String   @default("all")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Reference {
  id        String   @id @default(cuid())
  name      String
  role      String
  company   String?
  imageUrl  String
  text      String   @db.Text
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// Time Tracking & Invoicing Models
// ==========================================

model TimeEntry {
  id            String    @id @default(cuid())
  ticketKey     String
  ticketSummary String
  projectKey    String?
  projectName   String?
  startTime     DateTime
  endTime       DateTime?
  duration      Int?
  notes         String?   @db.Text
  invoiceId     String?
  invoice       Invoice?  @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([ticketKey])
  @@index([startTime])
  @@index([invoiceId])
}

model Invoice {
  id            String            @id @default(cuid())
  invoiceNumber String            @unique
  date          DateTime          @default(now())
  dueDate       DateTime?
  periodStart   DateTime?
  periodEnd     DateTime?
  status        String            @default("draft")
  clientName    String
  clientEmail   String?
  clientAddress String?           @db.Text
  fromName      String
  fromEmail     String?
  fromAddress   String?           @db.Text
  fromPhone     String?
  subtotal      Float             @default(0)
  taxRate       Float             @default(0)
  taxAmount     Float             @default(0)
  total         Float             @default(0)
  hourlyRate    Float?
  totalHours    Float?
  notes         String?           @db.Text
  workSummary   String[]
  lineItems     InvoiceLineItem[]
  timeEntries   TimeEntry[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model InvoiceLineItem {
  id          String    @id @default(cuid())
  invoiceId   String
  invoice     Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  type        String    @default("hourly")
  quantity    Float     @default(0)
  rate        Float     @default(0)
  amount      Float     @default(0)
  ticketKey   String?
  date        DateTime?
  dayOfWeek   String?
  sortOrder   Int       @default(0)

  @@index([invoiceId])
}

// French Quarter Direct — internal tool for managing New Orleans event listings
// (frenchquarterdirect.com). Additive models; existing data is untouched.
model FqdEvent {
  id                 String          @id @default(cuid())
  title              String
  slug               String          @unique
  startDate          DateTime
  endDate            DateTime?
  startTime          String?
  locationName       String?
  address            String?
  description        String?         @db.Text
  admission          String?
  website            String?
  category           String?
  subcategory        String?
  ticketUrl          String?
  organizer          String?
  expectedAttendance String?
  ageRequirement     String?
  notes              String?         @db.Text
  status             String          @default("draft") // draft | researched | approved | exported
  rawResearch        Json?
  // Set when the "event started" email has been sent, so it fires only once.
  startNotifiedAt    DateTime?
  // Marked true once the event has been published to French Quarter Direct (Joomla).
  addedToJoomla      Boolean         @default(false)
  images             FqdEventImage[]
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
}

model FqdEventImage {
  id           String   @id @default(cuid())
  eventId      String
  event        FqdEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  url          String
  cloudinaryId String?
  alt          String?
  order        Int      @default(0)
  createdAt    DateTime @default(now())

  @@index([eventId])
}
